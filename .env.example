# =============================================================
# BackupSMC — Variables de entorno
# Copia como .env y ajusta los valores antes del primer deploy
# NUNCA subas .env al repositorio
# =============================================================

# ── Seguridad ─────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# ── Base de datos ─────────────────────────────────────────────
# SQLite por defecto (no requiere configuración extra)
# Para PostgreSQL: postgresql://user:pass@host:5432/backupsmc
DATABASE_URL=sqlite:///./backupsmc.db

# ── Auth ──────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Token inicial para agentes (se migra a tabla agent_tokens al arrancar)
AGENT_TOKEN=change-me-agent-token
