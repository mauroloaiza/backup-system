# =============================================================
# BackupSMC — Variables de entorno
# Copia este archivo como .env y configura los valores
# NUNCA subas .env al repositorio
# =============================================================

# -------------------------------------------------------------
# General
# -------------------------------------------------------------
APP_ENV=development           # development | production
APP_NAME=BackupSMC
APP_VERSION=0.1.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true

# -------------------------------------------------------------
# Base de datos (PostgreSQL)
# -------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=backupsmc
POSTGRES_USER=backupsmc
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql+asyncpg://backupsmc:change-me@db:5432/backupsmc

# -------------------------------------------------------------
# Redis (Celery broker + cache)
# -------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------
# Servidor API
# -------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------------
# Frontend
# -------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1

# -------------------------------------------------------------
# Agente
# -------------------------------------------------------------
AGENT_SECRET=change-me-agent-secret
AGENT_PORT=9000

# -------------------------------------------------------------
# Almacenamiento local
# -------------------------------------------------------------
LOCAL_BACKUP_PATH=/var/backups/backupsmc

# -------------------------------------------------------------
# S3 / MinIO (opcional)
# -------------------------------------------------------------
S3_ENABLED=false
S3_ENDPOINT_URL=                  # Dejar vacío para AWS, o ej: http://minio:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=backupsmc-backups
S3_REGION=us-east-1

# -------------------------------------------------------------
# SFTP (opcional)
# -------------------------------------------------------------
SFTP_ENABLED=false
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_KEY_PATH=
SFTP_REMOTE_PATH=/backups

# -------------------------------------------------------------
# Google Drive via rclone (opcional)
# -------------------------------------------------------------
GDRIVE_ENABLED=false
GDRIVE_RCLONE_REMOTE=gdrive

# -------------------------------------------------------------
# Notificaciones
# -------------------------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=backupsmc@smcsoluciones.com

WEBHOOK_ENABLED=false
WEBHOOK_URL=

# -------------------------------------------------------------
# Retención por defecto
# -------------------------------------------------------------
DEFAULT_RETENTION_DAYS=30
